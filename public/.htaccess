# 1. VISIBILITY SETTINGS (Your Request)
# =====================================================
# 'Options +Indexes' tells the server to allow listing files.
# 'DirectoryIndex disabled' prevents index.php from loading automatically,
# forcing the server to show the file list instead.
Options +Indexes
DirectoryIndex disabled

# 2. SECURITY & UTILITY IMPROVEMENTS
# =====================================================
# Prevent 'MultiViews' confusion (good for consistent URLs)
Options -MultiViews

# Force HTTPS (Keep your site secure)
#<IfModule mod_rewrite.c>
    #RewriteEngine On
    #RewriteCond %{HTTPS} !=on
    #RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
#</IfModule>

# 3. PHP SETTINGS (Preserved from your original file)
# =====================================================
# These settings optimize file uploads and session handling.
# Note: These depend on your specific server modules (php8_module / lsapi_module).
<IfModule php8_module>
   php_flag display_errors On
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 256M
   php_value post_max_size 32M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php81"
   php_value upload_max_filesize 32M
   php_flag zlib.output_compression Off
</IfModule>

<IfModule lsapi_module>
   php_flag display_errors On
   php_value max_execution_time 30
   php_value max_input_time 60
   php_value max_input_vars 1000
   php_value memory_limit 256M
   php_value post_max_size 32M
   php_value session.gc_maxlifetime 1440
   php_value session.save_path "/var/cpanel/php/sessions/ea-php81"
   php_value upload_max_filesize 32M
   php_flag zlib.output_compression Off
</IfModule>